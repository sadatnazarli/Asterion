# ===========================================================================
# ASTERION — environment template. Copy to .env and fill. NEVER commit .env.
# ===========================================================================

# --- Database (Postgres + TimescaleDB + pgvector) ---
ASTERION_DB_HOST=localhost
ASTERION_DB_PORT=5432
ASTERION_DB_NAME=asterion
ASTERION_DB_USER=asterion
ASTERION_DB_PASSWORD=change_me
# embedding vector dimension — must match the embedding model below (nomic-embed-text = 768)
ASTERION_EMBED_DIM=768

# --- Redis / Celery ---
ASTERION_REDIS_URL=redis://localhost:6379/0

# --- Local LLM (Ollama is primary) ---
ASTERION_LLM_ENABLED=true
ASTERION_LLM_BACKEND=ollama            # ollama | openai_compatible
ASTERION_OLLAMA_BASE_URL=http://localhost:11434
ASTERION_LLM_MODEL=qwen2.5:7b-instruct
ASTERION_LLM_REASONING_MODEL=qwen2.5:14b-instruct
ASTERION_EMBED_MODEL=nomic-embed-text
ASTERION_LLM_TIMEOUT_S=120
ASTERION_LLM_MAX_RETRIES=3

# OpenAI-compatible local server (LM Studio / llama.cpp / vLLM) — used if backend=openai_compatible
ASTERION_OPENAI_COMPAT_BASE_URL=http://localhost:1234/v1
ASTERION_OPENAI_COMPAT_API_KEY=not-needed

# --- External LLM fallback: OFF by default (local-first). ---
ASTERION_ALLOW_EXTERNAL_LLM=false
# ASTERION_EXTERNAL_LLM_API_KEY=

# --- Ingestion: SEC EDGAR (REQUIRED compliant User-Agent: name + email) ---
# SEC requires this header; missing/abusive UA => IP ban. <10 req/s enforced in code.
ASTERION_SEC_USER_AGENT=Your Name (you@example.com)
ASTERION_SEC_MAX_RPS=8

# --- Ingestion: macro / prices ---
ASTERION_FRED_API_KEY=
ASTERION_PRICES_PROVIDER=stooq          # swappable provider; free default
# ASTERION_FMP_API_KEY=                  # post-MVP
# ASTERION_ALPACA_KEY=                   # post-MVP
# ASTERION_ALPACA_SECRET=

# --- Alerts (Telegram) ---
ASTERION_TELEGRAM_BOT_TOKEN=
ASTERION_TELEGRAM_CHAT_ID=

# --- App ---
ASTERION_ENV=dev
ASTERION_LOG_LEVEL=INFO
ASTERION_DATA_DIR=./data
