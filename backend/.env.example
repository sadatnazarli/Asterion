# ===========================================================================
# Asterion backend env template. Copy to backend/.env and fill. NEVER commit .env.
# All keys are OPTIONAL — Asterion degrades to stored/fallback data without them.
# Keys are accepted with or without the ASTERION_ prefix.
# ===========================================================================

# SEC EDGAR requires a compliant User-Agent with a real email (missing/abusive
# UA => IP ban). Required for SEC ingestion; everything else is optional.
ASTERION_SEC_USER_AGENT=

# --- Market data providers (all optional) ---
# Finnhub: live quotes.            https://finnhub.io
FINNHUB_API_KEY=
# FMP: beta + fundamentals.        https://financialmodelingprep.com
FMP_API_KEY=
# FRED: 10Y Treasury risk-free.    https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=
# Polygon: prices (optional).      https://polygon.io
POLYGON_API_KEY=
# OpenFIGI: symbol mapping.        https://www.openfigi.com/api
OPENFIGI_API_KEY=

# --- Database (Postgres + TimescaleDB + pgvector) ---
# Either DATABASE_URL, or the ASTERION_DB_* fields in the root .env.example.
DATABASE_URL=
